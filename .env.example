# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Providers (set at least one) ──────────────────────────
# The app supports three AI providers. Set at least one API key.
# If the primary provider fails or runs out of quota, the app falls back to others.
# IMPORTANT: Monitor your API usage and billing to avoid hitting quotas unexpectedly.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
XAI_API_KEY=...

# ── Web Search ───────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Site URL (for auth redirects) ────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
